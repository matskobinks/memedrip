# MemeDrip Overlay Client environment
# WebSocket relay URL (ws:// for local dev, wss:// for production with TLS)
VITE_WS_URL=ws://localhost:7878
# Your Discord user ID (the target who receives drops)
VITE_DISCORD_ID=your_discord_user_id_here
# Auth token — issued by the backend's TokenManager (HMAC-signed with expiry).
# To get a token, the backend will expose an endpoint or you can use the
# legacy format: sha256(RELAY_AUTH_SECRET : discordId)
# Generate via:
#   node -e "const c=require('crypto');const h=c.createHash('sha256');h.update('YOUR_SECRET:YOUR_DISCORD_ID');console.log(h.digest('hex'))"
VITE_AUTH_TOKEN=***]
