# ---- Backend env ----
# Discord application token for the bot
DISCORD_TOKEN=your_d...e
# Discord application/client ID (used for command registration)
DISCORD_CLIENT_ID=your_discord_client_id_here
# Discord guild ID for instant slash-command registration (leave blank for global)
DISCORD_GUILD_ID=
# Port the WebSocket relay server listens on
WS_PORT=7878
# Secret used to sign desktop-client auth tokens
RELAY_AUTH_SECRET=change...le
# Directory containing media files for /drop random (leave blank to disable)
MEDIA_DIR=/data/media
# TLS certificate path (leave blank for plaintext WS; set both for WSS)
TLS_CERT_PATH=
# TLS private key path
TLS_KEY_PATH=
# Health endpoint HTTP port
HEALTH_PORT=7879
# Log level: trace, debug, info, warn, error
LOG_LEVEL=info
